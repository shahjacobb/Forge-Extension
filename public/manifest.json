{
  "manifest_version": 3,
  "name": "Forge",
  "version": "0.0.1",
  "description": "Minimal pomodoro timer and session tracker with local progress insights.",
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Forge",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
